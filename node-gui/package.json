{
  "name": "bloodstone-node-gui",
  "productName": "Bloodstone Node",
  "version": "0.6.92",
  "description": "Bloodstone full node GUI for Windows",
  "main": "src/main.js",
  "author": "Bloodstone",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win --x64",
    "dist:portable": "electron-builder --win portable --x64"
  },
  "dependencies": {
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "org.bloodstone.nodegui",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/win64",
        "to": "bin",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "artifactName": "bloodstone-node-gui-0.6.9.2-win64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bloodstone Node"
    },
    "portable": {
      "artifactName": "bloodstone-node-gui-0.6.9.2-win64-portable.exe"
    }
  }
}