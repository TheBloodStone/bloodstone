# Copy to /etc/bloodstone/convergence.env on Pi edge nodes.
STORAGE_CREDIT_ENFORCE=1
COMPUTE_CREDIT_ENFORCE=1
BANDWIDTH_CREDIT_ENFORCE=1

DTN_NODE_ID=pi-edge-01
DTN_DEFAULT_REGION=lan
DTN_LAN_WEB_PORT=8887
DTN_AUTO_HEAL=1
DTN_AUTO_FLUSH=1
DTN_MDNS_ENABLE=1
DTN_MDNS_INTERVAL_SEC=30
DTN_GOSSIP_ENABLE=1
DTN_GOSSIP_PEERS_PER_ROUND=5

# Starlink / satellite handoff (Wave I) — flush DTN queue on brief uplink
DTN_STARLINK_ENABLE=1
DTN_STARLINK_PROBE_URL=https://bloodstonewallet.mytunnel.org/api/convergence/status
DTN_STARLINK_INTERFACE=
DTN_STARLINK_HANDOFF_COOLDOWN_SEC=300
DTN_STARLINK_FLUSH_LIMIT=5

# Offline Condenser reader (Wave J)
CONDENSER_OFFLINE_ENABLE=1

# TLS peer sync (self-signed cert from setup-dtn-pi-tls.sh)
DTN_TLS_PEER=1
DTN_TLS_VERIFY=0

BLOODSTONE_PUBLIC_ROOT=https://bloodstonewallet.mytunnel.org
BLURT_REGISTRY_RPC_NODES=https://rpc.blurt.blog,https://blurt-rpc.saboin.com