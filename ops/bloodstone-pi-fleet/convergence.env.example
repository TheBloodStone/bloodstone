# Copy to /etc/bloodstone/convergence.env on Pi edge nodes.
STORAGE_CREDIT_ENFORCE=1
COMPUTE_CREDIT_ENFORCE=1
BANDWIDTH_CREDIT_ENFORCE=1

DTN_NODE_ID=pi-edge-01
DTN_DEFAULT_REGION=lan
DTN_LAN_WEB_PORT=8887
DTN_AUTO_HEAL=1
DTN_AUTO_FLUSH=1
DTN_MDNS_ENABLE=1
DTN_MDNS_INTERVAL_SEC=30
DTN_GOSSIP_ENABLE=1
DTN_GOSSIP_PEERS_PER_ROUND=5

# Starlink / satellite handoff (Wave I) — flush DTN queue on brief uplink
DTN_STARLINK_ENABLE=1
DTN_STARLINK_PROBE_URL=https://bloodstonewallet.mytunnel.org/health
DTN_STARLINK_INTERFACE=
DTN_STARLINK_HANDOFF_COOLDOWN_SEC=300
DTN_STARLINK_FLUSH_LIMIT=5

# Offline Condenser reader (Wave J)
CONDENSER_OFFLINE_ENABLE=1

# Planetary DTN quorum (Wave K) — multi-region rollup + cross-region heal
DTN_PLANETARY_ENABLE=1
DTN_PLANETARY_MIN_REGIONS=1
DTN_PLANETARY_REGION_RATIO=0.8

# BLURT↔STONE bridge + atomic swaps (Wave L)
BRIDGE_SWAP_ENABLE=1
BLURT_BRIDGE_OUTPOST_ACCOUNT=bloodstone-bridge
BRIDGE_STONE_PER_BLURT=100000000
BRIDGE_SWAP_TTL_SEC=3600

# On-device AI routing (Wave M) + coordinator dispatch (Wave N)
AI_ROUTING_ENABLE=1
AI_PREFER_OFFLINE=1
AI_MDNS_ENABLE=1
AI_INFERENCE_PORT=8081
AI_AUTO_ROUTE_LIMIT=5
AI_FLOPS_PER_SEC=500000000
AI_COORDINATOR_DISPATCH_ENABLE=1
# Android LAN heartbeat: ai_runtimes + ai_inference_port on /api/lan/register

# Signed AI gossip + NPU auto-detect (Wave O)
AI_GOSSIP_SIGN_ENABLE=1
AI_GOSSIP_VERIFY=1
AI_GOSSIP_ALLOW_UNSIGNED=1
AI_NPU_DETECT_ENABLE=1
# Optional shared fleet key (recommended for production Pi mesh):
# AI_GOSSIP_SIGNING_KEY=change-me-fleet-secret

# Multi-tenant compute quota + Blurt AI provider sync (Wave P)
COMPUTE_TENANT_ENFORCE=1
DTN_DEFAULT_TENANT=bloodstone
# Per-author FLOPS cap (0 = use full STONE pool only)
# COMPUTE_TENANT_AUTHOR_CAP=5000000000

# Wave Q — inference shim + bandwidth tenant + fleet gossip enforcement
BANDWIDTH_TENANT_ENFORCE=1
# Wave R — storage tenant + AI DTN route export
STORAGE_TENANT_ENFORCE=1
AI_DTN_EXPORT_ROUTES=1

# Wave S — unified tenant dashboard + Blurt AI broadcast + runtime delegates
# AI_ONNX_MODEL_PATH=/var/lib/bloodstone/models/model.onnx
# AI_TFLITE_MODEL_PATH=/var/lib/bloodstone/models/model.tflite
# Per-author byte cap on DTN export (0 = use full STONE pool only)
# BANDWIDTH_TENANT_AUTHOR_CAP=104857600
# Shared fleet gossip key — when set, unsigned snapshots are rejected by default
# AI_GOSSIP_SIGNING_KEY=change-me-fleet-secret
# AI_GOSSIP_REQUIRE_FLEET_KEY=1
# Optional llama.cpp upstream for ai-inference shim:
# LLAMA_SERVER_URL=http://127.0.0.1:8080

# TLS peer sync (self-signed cert from setup-dtn-pi-tls.sh)
DTN_TLS_PEER=1
DTN_TLS_VERIFY=0

BLOODSTONE_PUBLIC_ROOT=https://bloodstonewallet.mytunnel.org
BLURT_REGISTRY_RPC_NODES=https://rpc.blurt.blog,https://blurt-rpc.saboin.com